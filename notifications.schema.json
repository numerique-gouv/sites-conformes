{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "title"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["info", "alert", "warning"]
          },
          "title":         { "type": "string", "minLength": 1 },
          "description":   { "type": "string" },
          "more_info_link": { "type": "string" },
          "start_date":    {
            "type": "string",
            "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$"
          },
          "end_date":      {
            "type": "string",
            "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$"
          }
        }
      }
    }
  }
}
